# Sao chép file này thành .env và điền thông tin thực
# KHÔNG commit file .env lên Git

# Jira MCP
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
# Lấy token tại: https://id.atlassian.com/manage-profile/security/api-tokens

# Jira Project (điền project key thực tế)
JIRA_PROJECT_KEY=QA
