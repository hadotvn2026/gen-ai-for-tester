{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": false
  },
  "playwright.reuseBrowser": false,
  "playwright.showTrace": true,
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": true
  },
  "files.exclude": {
    "node_modules": true,
    "playwright-report": false,
    "test-results": false
  }
}
